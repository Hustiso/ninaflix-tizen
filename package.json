{
  "name": "ninaflix-tizen",
  "version": "1.0.0",
  "description": "Premium streaming app for Samsung Tizen TV",
  "packageType": "app",
  "appName": "Ninaflix",
  "appPath": "index.html",
  "keys": [
    "MediaPlay",
    "MediaPause",
    "MediaPlayPause",
    "MediaFastForward",
    "MediaRewind",
    "MediaStop",
    "ColorF0Red",
    "ColorF1Green",
    "ColorF2Yellow",
    "ColorF3Blue"
  ],
  "main": "bridge/bridge.js",
  "scripts": {
    "start": "node bridge/bridge.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "cheerio-without-node-native": "^0.20.2",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2"
  }
}
